# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=智能化学实验评估系统
APP_VERSION=0.1.0
DEBUG=false

# 数据库配置
DB_DATABASE_URL=sqlite:///chemistry_lab.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# 大模型API配置
LLM_API_KEY=your-openai-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-3.5-turbo
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_REQUESTS_PER_MINUTE=60

# YOLO模型配置
YOLO_MODEL_PATH=models/yolov8n_chemistry.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=100
YOLO_DEVICE=cpu
YOLO_BATCH_SIZE=1
YOLO_INPUT_SIZE=640

# 用户界面配置
UI_PAGE_TITLE=智能化学实验评估系统
UI_PAGE_ICON=🧪
UI_LAYOUT=wide
UI_HOST=localhost
UI_PORT=8501
UI_CAMERA_INDEX=0
UI_VIDEO_WIDTH=640
UI_VIDEO_HEIGHT=480
UI_FPS=30
UI_THEME=light
UI_PRIMARY_COLOR=#1f77b4

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 日志配置
LOG_LEVEL=INFO